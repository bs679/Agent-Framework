{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openclaw/openclaw/agent-config-schema",
  "title": "Agent Config Schema",
  "description": "Validates frontmatter blocks across all 6 agent configuration files",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/SoulConfig" },
    { "$ref": "#/$defs/UserConfig" },
    { "$ref": "#/$defs/IdentityConfig" },
    { "$ref": "#/$defs/AgentsConfig" },
    { "$ref": "#/$defs/HeartbeatConfig" },
    { "$ref": "#/$defs/MemoryConfig" }
  ],
  "$defs": {
    "SlugCase": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
      "description": "Lowercase letters, digits, and hyphens only. Must start with a letter."
    },
    "HHMMTime": {
      "type": "string",
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
      "description": "24-hour time in HH:MM format"
    },
    "BaseFields": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "Schema version string (e.g. '1.0')"
        },
        "agent_id": {
          "$ref": "#/$defs/SlugCase",
          "description": "Unique agent identifier in slug-case"
        }
      },
      "required": ["version", "agent_id"]
    },
    "SoulConfig": {
      "allOf": [
        { "$ref": "#/$defs/BaseFields" },
        {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "agent_id": { "$ref": "#/$defs/SlugCase" },
            "personality_traits": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "List of core personality traits"
            },
            "communication_style": {
              "type": "string",
              "description": "How the agent communicates with its owner"
            },
            "values": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Core values that guide agent behavior"
            },
            "bad_news_approach": {
              "type": "string",
              "description": "How the agent delivers difficult information"
            }
          },
          "required": ["personality_traits", "communication_style", "values", "bad_news_approach"],
          "additionalProperties": false
        }
      ]
    },
    "UserConfig": {
      "allOf": [
        { "$ref": "#/$defs/BaseFields" },
        {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "agent_id": { "$ref": "#/$defs/SlugCase" },
            "owner_name": {
              "type": "string",
              "description": "Full name of the human this agent serves"
            },
            "owner_role": {
              "type": "string",
              "description": "The human's role in the organization"
            },
            "pronouns": {
              "type": "string",
              "description": "Preferred pronouns (e.g. he/him, she/her, they/them)"
            },
            "energy_pattern": {
              "type": "string",
              "enum": ["morning", "mid-morning", "afternoon", "evening", "variable"],
              "description": "When the person is most productive"
            },
            "focus_style": {
              "type": "string",
              "enum": ["deep_blocks", "pomodoro", "flow_based"],
              "description": "Preferred focus and work session style"
            },
            "overwhelm_triggers": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Situations that cause the person to feel overwhelmed"
            },
            "information_format": {
              "type": "string",
              "enum": ["bullets", "prose", "tables", "mixed"],
              "description": "Preferred format for receiving information"
            },
            "current_time_sinks": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Activities currently consuming disproportionate time"
            }
          },
          "required": [
            "owner_name",
            "owner_role",
            "pronouns",
            "energy_pattern",
            "focus_style",
            "overwhelm_triggers",
            "information_format",
            "current_time_sinks"
          ],
          "additionalProperties": false
        }
      ]
    },
    "IdentityConfig": {
      "allOf": [
        { "$ref": "#/$defs/BaseFields" },
        {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "agent_id": { "$ref": "#/$defs/SlugCase" },
            "agent_name": {
              "oneOf": [
                { "type": "string" },
                { "type": "string", "const": "self_selected" }
              ],
              "description": "Agent name. Use 'self_selected' to let the agent choose its own name at first boot."
            },
            "avatar_description": {
              "type": "string",
              "description": "Visual or character description of the agent's persona"
            },
            "role_definition": {
              "type": "string",
              "description": "What this agent is responsible for and its scope"
            },
            "organization": {
              "type": "string",
              "description": "The organization this agent operates within"
            }
          },
          "required": ["agent_name", "avatar_description", "role_definition", "organization"],
          "additionalProperties": false
        }
      ]
    },
    "AgentsConfig": {
      "allOf": [
        { "$ref": "#/$defs/BaseFields" },
        {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "agent_id": { "$ref": "#/$defs/SlugCase" },
            "plane_name": {
              "type": "string",
              "description": "Name of the Agents Plane this agent belongs to"
            },
            "collaborates_with": {
              "type": "array",
              "items": { "$ref": "#/$defs/SlugCase" },
              "description": "agent_ids of agents this agent collaborates with"
            },
            "escalation_path": {
              "type": "string",
              "description": "Who/what to escalate to when the agent cannot resolve something"
            },
            "shared_tools": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tool names shared across the agents plane"
            }
          },
          "required": ["plane_name", "collaborates_with", "escalation_path", "shared_tools"],
          "additionalProperties": false
        }
      ]
    },
    "HeartbeatConfig": {
      "allOf": [
        { "$ref": "#/$defs/BaseFields" },
        {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "agent_id": { "$ref": "#/$defs/SlugCase" },
            "morning_checkin_time": {
              "$ref": "#/$defs/HHMMTime",
              "description": "Time for the morning check-in (HH:MM, 24h)"
            },
            "evening_checkin_time": {
              "$ref": "#/$defs/HHMMTime",
              "description": "Time for the evening check-in (HH:MM, 24h)"
            },
            "reflection_triggers": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Events that trigger an unscheduled agent reflection"
            },
            "snooze_limit": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum number of times a check-in can be snoozed"
            },
            "energy_aware": {
              "type": "boolean",
              "description": "Whether the agent adapts its check-in style based on owner energy level"
            }
          },
          "required": [
            "morning_checkin_time",
            "evening_checkin_time",
            "reflection_triggers",
            "snooze_limit",
            "energy_aware"
          ],
          "additionalProperties": false
        }
      ]
    },
    "MemoryConfig": {
      "allOf": [
        { "$ref": "#/$defs/BaseFields" },
        {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "agent_id": { "$ref": "#/$defs/SlugCase" },
            "retention_days_short": {
              "type": "integer",
              "minimum": 1,
              "description": "Days to retain short-term memory entries"
            },
            "retention_days_long": {
              "type": "integer",
              "minimum": 1,
              "description": "Days to retain long-term memory entries"
            },
            "encrypt_at_rest": {
              "type": "boolean",
              "const": true,
              "description": "Memory must always be encrypted at rest. Must be true."
            },
            "sensitive_categories": {
              "type": "array",
              "items": { "type": "string" },
              "contains": {
                "type": "string",
                "enum": [
                  "member_data",
                  "grievance_details",
                  "negotiation_strategy",
                  "financial_account_info",
                  "executive_session_content"
                ]
              },
              "minContains": 5,
              "description": "All 5 sensitive categories must be present: member_data, grievance_details, negotiation_strategy, financial_account_info, executive_session_content"
            },
            "forget_on_request": {
              "type": "boolean",
              "description": "Whether the agent will delete memory entries on owner request"
            }
          },
          "required": [
            "retention_days_short",
            "retention_days_long",
            "encrypt_at_rest",
            "sensitive_categories",
            "forget_on_request"
          ],
          "additionalProperties": false
        }
      ]
    }
  }
}
