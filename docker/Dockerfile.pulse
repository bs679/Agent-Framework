FROM python:3.12-slim

WORKDIR /app

# System deps for psycopg2 binary wheel
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY integrations/pulse/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . /app

# Run as non-root
RUN groupadd -r pulse && useradd -r -g pulse -d /app -s /sbin/nologin pulse \
    && chown -R pulse:pulse /app

USER pulse

EXPOSE 8000

CMD ["uvicorn", "integrations.pulse.app:app", "--host", "0.0.0.0", "--port", "8000"]
