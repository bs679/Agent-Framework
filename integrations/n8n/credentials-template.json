{
  "_comment": "n8n credential structure for AIOS/Pulse workflows. NO secrets — fill values in n8n UI. See README.md for setup instructions.",
  "credentials": [
    {
      "id": "ms-graph-oauth2",
      "name": "MS Graph OAuth2",
      "type": "microsoftGraphOAuth2",
      "data": {
        "clientId": "",
        "clientSecret": "",
        "tenantId": "",
        "scope": "Calendars.Read Mail.Read User.Read",
        "authUrl": "https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/authorize",
        "accessTokenUrl": "https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/token"
      },
      "usedIn": [
        "01-daily-context-builder.json"
      ]
    },
    {
      "id": "pulse-api-token",
      "name": "Pulse API Token",
      "type": "httpHeaderAuth",
      "data": {
        "name": "Authorization",
        "value": ""
      },
      "usedIn": [
        "01-daily-context-builder.json",
        "02-grievance-deadline-monitor.json",
        "03-legislative-calendar-tracker.json",
        "04-weekly-report-aggregator.json",
        "05-email-thread-intelligence.json",
        "06-new-member-orientation.json"
      ]
    },
    {
      "id": "ollama-config",
      "name": "Ollama Local",
      "type": "custom",
      "data": {
        "baseUrl": "http://localhost:11434",
        "model": "llama3.1:8b"
      },
      "note": "Ollama runs locally. The base URL is hardcoded to localhost in workflow HTTP Request nodes. Change only if Ollama runs on a different host/port.",
      "usedIn": [
        "03-legislative-calendar-tracker.json",
        "04-weekly-report-aggregator.json",
        "05-email-thread-intelligence.json"
      ]
    },
    {
      "id": "ms-teams-webhook",
      "name": "MS Teams Webhook URL",
      "type": "custom",
      "data": {
        "webhookUrl": ""
      },
      "note": "Create an Incoming Webhook connector in the target MS Teams channel. Paste the URL here.",
      "usedIn": [
        "02-grievance-deadline-monitor.json"
      ]
    }
  ],
  "environment_variables": {
    "PULSE_API_BASE_URL": {
      "description": "Base URL for the Pulse API (e.g., http://localhost:8000)",
      "value": "",
      "usedAs": "Referenced via n8n expressions: $credentials.pulseApiBaseUrl"
    },
    "MS_TEAMS_WEBHOOK_URL": {
      "description": "MS Teams incoming webhook URL for urgent alerts",
      "value": "",
      "usedAs": "Referenced via n8n expressions: $credentials.msTeamsWebhookUrl"
    }
  }
}
