# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Environment — never commit secrets
.env
agents/*/.env
.venv/
venv/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# SQLite dev databases
*.db
*.sqlite
*.sqlite3

# Backups — large binary archives stay off git
backups/

# SSL keys — never commit private keys
*.key
*.pem
nginx/ssl/

# n8n exports — may contain credential snippets; review before committing
# integrations/n8n/workflows/*.json   # uncomment to exclude workflow exports

# Terraform state — may contain sensitive outputs
provisioning/terraform/*.tfstate
provisioning/terraform/*.tfstate.backup
provisioning/terraform/.terraform/
