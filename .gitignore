# =============================================================================
# AIOS/PULSE — Agent Framework .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Critical: Agent data that must never be committed
# -----------------------------------------------------------------------------
agents/*/memory/
agents/*/.env

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.venv/
venv/
ENV/
env/
.env
.env.*
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
*.mo
*.pot

# -----------------------------------------------------------------------------
# Node / JavaScript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
dist/
.next/
.nuxt/
.output/
.cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
terraform/*.tfstate
terraform/*.tfstate.*
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfvars
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json
.terraformrc
terraform.rc

# -----------------------------------------------------------------------------
# Secrets and credentials
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks
secrets/
.secrets/
gcp-credentials.json
service-account*.json

# -----------------------------------------------------------------------------
# OS / editor artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
