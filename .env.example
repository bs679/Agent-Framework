# AIOS/Pulse Environment Configuration
# Copy to .env and fill in values.

# ---------------------------------------------------------------------------
# AI Models
# ---------------------------------------------------------------------------

# Ollama — local AI (always enabled, primary for sensitive data)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# NVIDIA NIM / Kimi K2 — external AI for non-sensitive, quality-critical tasks
NVIDIA_API_KEY=                    # Get from build.nvidia.com — leave blank to disable Kimi
KIMI_ENABLED=false                 # Set true once NVIDIA_API_KEY is configured

# Anthropic Claude — external AI fallback
ANTHROPIC_API_KEY=                 # Leave blank to disable Claude
CLAUDE_ENABLED=false               # Set true to enable Claude as fallback

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector — Phase 10 production)
# ---------------------------------------------------------------------------

# Full async connection URL for SQLAlchemy/asyncpg (production)
DATABASE_URL=postgresql+asyncpg://pulse:CHANGE_ME@localhost:5432/aios_pulse
# Dev SQLite fallback (used if DATABASE_URL is not set)
PULSE_DB_URL=sqlite:///./pulse.db
PULSE_DB_ECHO=false                 # Set true to log SQL queries (dev only)

# docker-compose postgres service variables
POSTGRES_DB=aios_pulse
POSTGRES_USER=pulse
POSTGRES_PASSWORD=CHANGE_ME        # Generate with: openssl rand -base64 32

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Pulse API
# ---------------------------------------------------------------------------

# Azure AD — required for JWT auth
AZURE_AD_TENANT_ID=                 # Your Azure AD tenant UUID
AZURE_AD_CLIENT_ID=
AZURE_AD_AUDIENCE=api://pulse-app
PULSE_DEV_MODE=false                # Set true ONLY for local dev (disables JWT signature check)

# Agent plane
AGENT_PLANE_ENABLED=true
AGENT_PLANE_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Phase 9a — Grievance deadline monitoring
# ---------------------------------------------------------------------------

GRIEVANCE_ALERT_WINDOW_DAYS=7       # Alert when deadline is within N days
GRIEVANCE_ARBITRATION_DAYS=30       # Default days from Step 2 to arbitration filing deadline
PRESIDENT_AGENT_ID=dave-president   # Agent ID for the President's checkin alerts
PULSE_BASE_URL=http://localhost:8000 # Used by the scheduler to POST checkin alerts
SCHEDULER_SERVICE_TOKEN=dev-scheduler-token  # Prod: long-lived service JWT from Azure AD

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------

# n8n webhook for MS Teams alerts (Teams channel alerts only — no email)
N8N_HEALTH_WEBHOOK_URL=            # e.g. http://localhost:5678/webhook/healthcheck

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Comma-separated allowed CORS origins (Tauri desktop + local dev)
CORS_ORIGINS=tauri://localhost,http://localhost:5173,http://localhost:3000
